<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed if your HTML pulls external scripts/images -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="My HTML Game"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen">
        
        <!-- The dot before MainActivity tells it to use the namespace from build.gradle -->
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.action.LAUNCHER" />
            </intent-filter>
        </activity>
        
    </application>
</manifest>
